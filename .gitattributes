# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Pike source files
*.pike text eol=lf
*.pmod text eol=lf
*.h text eol=lf

# Documentation
*.md text eol=lf diff=markdown
*.txt text eol=lf

# Config files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files (explicit)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
